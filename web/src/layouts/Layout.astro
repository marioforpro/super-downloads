---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://superdownloads.app" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://superdownloads.app" />
    <meta property="og:image" content="https://superdownloads.app/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://superdownloads.app/og.png" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Super Downloads",
      "description": "macOS video downloader for editors. Save your own, licensed, or authorized videos from YouTube, TikTok and Vimeo — plus Instagram, Facebook, X and LinkedIn using your browser login. Every video is Premiere Pro ready — H.264/MP4.",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "macOS 10.13+",
      "offers": [
        {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR",
          "name": "Free",
          "description": "5 downloads per day, all platforms, all quality options"
        },
        {
          "@type": "Offer",
          "price": "29",
          "priceCurrency": "EUR",
          "name": "Pro — Lifetime",
          "description": "Unlimited downloads, 3 devices, priority updates"
        }
      ],
      "featureList": [
        "Works out of the box with YouTube, TikTok and Vimeo",
        "Supports Instagram, Facebook, X/Twitter and LinkedIn using your browser login",
        "Auto-convert to H.264/AAC/MP4 for editing",
        "Hardware accelerated with VideoToolbox",
        "Audio-only MP3 extraction",
        "Clipboard auto-detection",
        "Drag and drop support",
        "Apple Silicon and Intel support"
      ],
      "url": "https://superdownloads.app",
      "downloadUrl": "https://superdownloads.app/#download",
      "softwareVersion": "1.1",
      "creator": {
        "@type": "Organization",
        "name": "Super Downloads",
        "url": "https://superdownloads.app"
      }
    }
    </script>
