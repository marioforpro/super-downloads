<style is:global>
  :root {
    --navy-dark: #0a163f;
    --navy-mid: #162b73;
    --blue-bright: #30a7ff;
    --blue-light: #8cd0ff;
    --blue-pale: #d5ebff;
    --white: #ffffff;
    --gray-100: #f4f7fc;
    --gray-200: #e2e8f0;
    --gray-400: #94a3b8;
    --gray-600: #475569;
    --gray-900: #0f172a;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Inter", "SF Pro Text", "Segoe UI", sans-serif;
    color: var(--gray-900);
    background: var(--white);
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: var(--blue-bright);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
