{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Super Downloads",
  "version": "1.1.1",
  "identifier": "com.supermac.super-downloads",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Super Downloads",
        "width": 480,
        "height": 400,
        "minWidth": 400,
        "maxWidth": 600,
        "minHeight": 300,
        "resizable": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMTE5M0EzOEIyNTEyNDEKUldSQkVpV0xvNU1SdnZjRzIwS0ZJZ3I5MnhveFg3QUtCOXU4UzlUdUZ2UGJzdnBCeFBucGhMaWQK",
      "endpoints": [
        "https://github.com/marioforpro/super-downloads/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  }
}
